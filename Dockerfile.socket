FROM node:20-alpine

WORKDIR /app

COPY package.json package-lock.json* ./
RUN npm ci --omit=dev

COPY server/ ./server/
COPY tsconfig.json ./

RUN npx tsc server/socket.ts --outDir dist --esModuleInterop --resolveJsonModule --module commonjs --target es2020 --skipLibCheck || true

EXPOSE 3001

ENV NODE_ENV=production
ENV SOCKET_PORT=3001

CMD ["node", "dist/socket.js"]
